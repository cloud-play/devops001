pipeline {
    agent any

    tools {
        // Change this to match your Jenkins Tool Name
        maven 'Maven_Home' 
    }

    environment {
        // The directory where your Tomcat is installed
        TOMCAT_PATH = '/opt/tomcat/webapps'
        // The path to your project folder inside the GitHub repo
        PROJECT_DIR = 'devops-ci-cd-webapp'
    }

    stages {
        stage('Git Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/cloud-play/devops001.git'
            }
        }

        stage('Compile & PMD') {
            steps {
                // -f points Maven to the subfolder containing the pom.xml
                sh "mvn -f ${PROJECT_DIR}/pom.xml clean compile pmd:pmd"
            }
        }

        stage('Trivy FS Scan') {
            steps {
                // Scans the specific project folder for vulnerabilities
                sh "trivy fs ${PROJECT_DIR} > trivy-fs-report.txt"
                sh 'cat trivy-fs-report.txt'
            }
        }

        stage('Unit Test & Coverage') {
            steps {
                // 'verify' handles surefire tests and jacoco reports
                sh "mvn -f ${PROJECT_DIR}/pom.xml verify"
            }
            post {
                always {
                    // Publishes the test results to the Jenkins UI
                    junit "**/target/surefire-reports/*.xml"
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                // 'SonarQube-Server' must match the name in Manage Jenkins > System
                withSonarQubeEnv('SonarQube-Server') {
                    sh "mvn -f ${PROJECT_DIR}/pom.xml sonar:sonar"
                }
            }
        }
        stage("Quality Gate") {
    steps {
        timeout(time: 1, unit: 'HOURS') {
            // This waits for SonarQube to finish processing and returns the status
            waitForQualityGate abortPipeline: true
        }
    }
}

        stage('Package') {
            steps {
                // Generate the .war file
                sh "mvn -f ${PROJECT_DIR}/pom.xml package -DskipTests"
            }
        }

        stage('Deploy to Tomcat') {
    steps {
        // This copies the WAR file to the location you just fixed
        sh "cp ${WORKSPACE}/${PROJECT_DIR}/target/*.war /opt/tomcat/webapps/devops-app.war"
    }
}
    }

    post {
        success {
            echo "Successfully completed build for Kubebytes DevOps Project!"
        }
        failure {
            echo "Pipeline failed. Check the logs for Maven tool errors or directory issues."
        }
    }
}
